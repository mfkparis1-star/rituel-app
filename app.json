{
  "expo": {
    "name": "Rituel",
    "slug": "rituel",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rituel",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08080E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mfkparis.rituel",
      "buildNumber": "8",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#08080E"
      },
      "package": "com.mfkparis.rituel",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Rituel utilise vos photos pour votre archive beauté et votre journal peau.",
          "cameraPermission": "Rituel utilise la caméra pour scanner vos produits."
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "2650765f-b690-41db-966d-5fe6288603ec"
      },
      "router": {}
    },
    "owner": "rituel-app"
  }
}